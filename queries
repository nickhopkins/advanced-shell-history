CONTEXT: {
  description: "Context query"
  sql: {
    select distinct
      datetime(c.start_time, 'unixepoch', 'localtime') as 'when',
      c.command as what,
      c.cwd as 'where'
    from
      commands as c
      inner join ( select id-3 as min_id, id+3 as max_id 
                     from commands 
                    where command regexp '${ASH_QARG}'
                 ) s 
                 on id >= s.min_id and id <= s.max_id;
    order by 1 asc 
    ;
  }
}

REGEX_LIMIT: {
  description: "regex queries"
  sql: {
  select * from (
    select
      datetime(c.start_time, 'unixepoch', 'localtime') as 'when',
      c.command as what
    from
      commands as c
    where command regexp '${ASH_QARG}'    
    order by 1 desc
    limit ${ASH_QLIMIT:-10}
    )
    order by 1 asc
    ;
  }
}

WEIGHTED: {
  description: "weighted by count and most recent"
  sql: {
    select command
      from (
            select command
                  , sum(wgt * bonus) frec
              from (
                      select command
                          -- decay is ln(2)/30 (days)
                          , exp(- 0.0231049060186648 * (unixepoch() - c.start_time) / 86400)  wgt
                          , iif(cwd = '${PWD}', 3, 1) as bonus
                        from commands c
                            join sessions s
                                  on c.session_id = s.id
                      where command regexp '${ASH_QARG}'
                        and uid = 1001
                    )
              group by command
              order by sum(wgt * bonus) desc
              limit 40
          )
    order by frec asc
  }
}

FULL_WEIGHTED: {
  description: "weighted by count and most recent"
  sql: {
    select * from (
      select command, max(start_time) st, printf( "%.2e", (sum(wgt))) swgt
           , sum(bonus) sbon, printf( "%.2e", sum(wgt*bonus)) frec
           , min('${PWD}') mpwd
        from (select command
                  , datetime(c.start_time, 'unixepoch', 'localtime') as start_time
                    -- decay is ln(2)/30 (days)
                  , exp(- 0.0231049060186648 * (unixepoch() - c.start_time) / 86400) wgt
                  , iif(cwd = '${PWD}', 3, 1) as bonus
              from commands c
              join sessions s
                on c.session_id = s.id
              where command regexp '${ASH_QARG}'
                and uid = 1001)
      group by command
      order by sum(wgt*bonus) desc 
      limit ${ASH_QLIMIT:-40}
    )
    order by frec asc
  }
}
