DEMO: {
  description: "Shows who did what, where and when (not WHY)."
  sql: {
    select
      s.logname as who,
      c.session_id,
      c.cwd as 'where',
      datetime(c.start_time, 'unixepoch', 'localtime') as 'when',
      c.command as what
    from
      commands as c
      inner join sessions as s
        on c.session_id = s.id
    order by 1, 2, 4
    ;
  }
}

WIP: {
  description: "Shows last 3 months"
  sql: {
    select
      c.session_id,
      c.cwd as 'where',
      datetime(c.start_time, 'unixepoch', 'localtime') as 'when',
      c.command as what
