  }
}


CWD: {
  description: "Shows the history for the current working directory only."
  sql: {
    select
      c.session_id as "session",
      datetime(c.start_time, 'unixepoch', 'localtime') as "when",
      c.command as "what"
    from
      commands as c
    where
      c.cwd = '${PWD}' or c.cwd = '/${PWD}' or c.cwd = '/${PWD#//}'
    order by 2, 1
    ;
  }
}


RCWD: {
  description: "Shows the history rooted at the current working directory."
  sql: {
    select
      -- c.session_id as "session",
      c.cwd as "where",
      datetime(c.start_time, 'unixepoch', 'localtime') as "when",
      c.command as "what"
    from
      commands as c
    where
      c.cwd regexp '^${PWD}' 
    order by c.id
    ;
  }
}

BY_DIR: {
  description: "Shows the history rooted at $ASH_QARG"
  sql: {
    select
      -- c.session_id as "session",
      c.cwd as "where",
      datetime(c.start_time, 'unixepoch', 'localtime') as "when",
      c.command as "what"
    from
      commands as c
    where
      c.cwd regexp '${ASH_QARG}'
    order by c.id
    ;
  }
}

RCWD_NO_DUPE: {
  description: "Shows the uniq history rooted at the current working directory."
  sql: {
    select
      c.cwd as "where",
      datetime(max(c.start_time), 'unixepoch', 'localtime') as "when",
      c.command as "what"
    from
      commands as c
    where
      c.cwd regexp '^${PWD}'
    group by c.cwd, c.command
    order by max(c.id) 
    ;
  }
}


ME: {
  description: "Select the history for just the current session."
  sql: {
    select
      c.session_id as 'session',
      c.cwd as 'current_working_dir',
      c.command_no as 'cmd',
      datetime(c.start_time, 'unixepoch', 'localtime') as start_time,
      c.duration as 'secs',
      c.rval as exit,
      c.command
    from
      commands as c
      left outer join sessions as s
        on c.session_id = s.id
    where
      c.session_id = ${ASH_SESSION_ID:-0}
    order by
      c.id
    ;
  }
}

ALL_HIST_NO_DUPE: {
  description: "all history, no duplicates"
  sql: {
    select
      datetime(max(c.start_time), 'unixepoch', 'localtime') as 'when',
      c.command as what
    from
      commands as c
    group by c.command
    order by 1
    ;
  }
}

BASH_CWD_HISTORY: {
  description: "Bash history for current_working_dir toggle"
  sql: {
    select max(start_time) as start_time
         , command 
      from commands      
     where cwd = '${PWD}'
     group by command
     order by 1 asc
    ;
  }
}

BASH_GLOBAL_HISTORY: {
  description: "Bash history for current_working_dir"
  sql: {
    select max(start_time) as start_time
         , command 
      from commands
     where command not regexp '^hh[gt]'
    group by command
    order by 1 asc
    ;
  }
}

RECENT: {
  description: "recent queries"
  sql: {
    select
      datetime(c.start_time, 'unixepoch', 'localtime') as 'when',
      c.command as what
    from
      commands as c
    order by 1 desc 
    limit ${ASH_QLIMIT:-20}
    ;
  }
}

